rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global safety net - deny all by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 256;
    }

    // Entity validations
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email'])
        && data.uid == request.auth.uid
        && data.email is string;
    }

    function isValidTask(data) {
      return data.userId == request.auth.uid
        && data.title is string;
    }

    function isValidMoodLog(data) {
      return data.userId == request.auth.uid
        && data.energyLevel is string;
    }

    function isValidChatMessage(data) {
      return data.userId == request.auth.uid
        && data.role is string
        && data.content is string;
    }

    // Collection matches
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
      allow delete: if false;

      match /tasks/{taskId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(taskId) && isValidTask(request.resource.data);
        allow update: if isOwner(userId) && isValidId(taskId) && isValidTask(request.resource.data);
        allow delete: if isOwner(userId) && isValidId(taskId);
      }

      match /moodLogs/{logId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(logId) && isValidMoodLog(request.resource.data);
        allow update: if isOwner(userId) && isValidId(logId) && isValidMoodLog(request.resource.data);
        allow delete: if isOwner(userId) && isValidId(logId);
      }

      match /chats/{chatId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(chatId) && isValidChatMessage(request.resource.data);
        allow update: if false;
        allow delete: if isOwner(userId) && isValidId(chatId);
      }

      match /saved_chats/{savedChatId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(savedChatId);
        allow update: if false;
        allow delete: if isOwner(userId) && isValidId(savedChatId);
      }
    }
  }
}
